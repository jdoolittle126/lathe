@page "/"
@implements IDisposable
@using System.Globalization
@using Lathe.Core.Domain
@using Lathe.Web.Features.Session
@inject LatheSessionState Session
@inject ILatheSessionController SessionController

<PageTitle>Lathe</PageTitle>

<div class="page @GetPageClass()">
    @{
        var events = Session.Events;
        var levelCounts = CountLevels(FilterWithoutLevelToggles(events));
        var filteredEvents = ApplyLevelToggles(FilterWithoutLevelToggles(events))
            .OrderByDescending(logEvent => logEvent.Timestamp)
            .ToList();
        var selectedEvent = GetSelectedEvent(filteredEvents);
        var showControls = !_controlsCollapsed || Session.Sources.Count == 0;
        var activeFilterSummary = GetActiveFilterSummary();
    }

    <header class="masthead">
        <div>
            <p class="eyebrow">Local Log Workbench</p>
            <h1>Lathe</h1>
        </div>

        <div class="masthead-actions">
            <div class="snapshot-meta">
                <span>@Session.Sources.Count source(s)</span>
                <span>@events.Count event(s)</span>
                <span>Loaded @Session.LoadedAt.LocalDateTime.ToString("yyyy-MM-dd HH:mm:ss", CultureInfo.InvariantCulture)</span>
                <span>Updated @Session.LastUpdatedAt.LocalDateTime.ToString("yyyy-MM-dd HH:mm:ss", CultureInfo.InvariantCulture)</span>
                <span class="live-pill">Live</span>
            </div>

            <button type="button" class="filter-button" @onclick="ToggleControls">
                @(_controlsCollapsed ? "Show controls" : "Hide controls")
            </button>
        </div>
    </header>

    @if (Session.LoadError is not null)
    {
        <section class="status-panel error">
            <h2>Session failed</h2>
            <p>@Session.LoadError</p>
        </section>
    }

    @if (_controlsCollapsed && Session.Sources.Count > 0)
    {
        <section class="controls-summary">
            <span>@Session.Sources.Count source(s) ready</span>
            @if (!string.IsNullOrWhiteSpace(activeFilterSummary))
            {
                <span>@activeFilterSummary</span>
            }
        </section>
    }

    @if (_sourceErrors.Count > 0)
    {
        <section class="status-panel error compact-status">
            <h2>Could not add source</h2>
            @foreach (var error in _sourceErrors)
            {
                <p>@error</p>
            }
        </section>
    }

    @if (showControls)
    {
        <section class="source-entry-strip">
            <div class="source-entry-copy">
                <p class="eyebrow">Add Source</p>
                <strong>Bring more logs onto the bench without restarting `serve`.</strong>
            </div>

            <label class="filter-field">
                <span>Type</span>
                <select @bind="_sourceKind">
                    <option value="File">File</option>
                    <option value="Glob">Glob</option>
                    <option value="Rolling">Rolling directory</option>
                </select>
            </label>

            <label class="filter-field source-entry-path">
                <span>Path</span>
                <input @bind="_sourceInput" placeholder="sample-logs/web-01.json" />
            </label>

            <div class="filter-actions source-entry-actions">
                <button type="button" class="filter-button primary" @onclick="AddSourceAsync" disabled="@_isAddingSource">
                    @(_isAddingSource ? "Adding..." : "Add source")
                </button>
            </div>
        </section>
    }

    @if (Session.Sources.Count == 0)
    {
        <section class="status-panel">
            <h2>No sources loaded</h2>
            <p>Start with <code>lathe serve</code> and add a file, glob, or rolling directory here in the UI.</p>
        </section>
    }

    @if (Session.Sources.Count > 0)
    {
        @if (showControls)
        {
            <section class="source-strip">
                @foreach (var source in Session.Sources)
                {
                    <article class="source-card" style="@GetSourceStyle(source.Path)">
                        <div class="source-card-header">
                            <span class="source-swatch"></span>
                            <span class="source-kind">@source.Kind</span>
                        </div>
                        <strong>@source.DisplayName</strong>
                        <span class="source-path">@source.Path</span>
                    </article>
                }
            </section>

            <section class="filter-strip">
                <label class="filter-field">
                    <span>Text</span>
                    <input @bind="_draftText" placeholder="message, exception, or raw" />
                </label>

                <label class="filter-field">
                    <span>Property</span>
                    <input @bind="_draftPropertyName" placeholder="MachineName" />
                </label>

                <label class="filter-field">
                    <span>Value</span>
                    <input @bind="_draftPropertyValue" placeholder="web-01" />
                </label>

                <label class="filter-field">
                    <span>Source</span>
                    <select @bind="_draftSource">
                        <option value="">All sources</option>
                        @foreach (var source in Session.Sources)
                        {
                            <option value="@source.DisplayName">@source.DisplayName</option>
                        }
                    </select>
                </label>

                <label class="filter-field">
                    <span>Filters</span>
                    <div class="filter-actions">
                        <button type="button" class="filter-button primary" @onclick="ApplyFilters">Apply</button>
                        <button type="button" class="filter-button" @onclick="ClearFilters">Clear</button>
                    </div>
                </label>
            </section>
        }

        @if (events.Count == 0)
        {
            <section class="status-panel">
                <h2>No events turned up yet</h2>
                <p>The sources are loaded, but the current snapshot is empty.</p>
            </section>
        }
        else
        {
            <section class="metric-strip">
                <article class="metric-card shown-card">
                    <span>Shown</span>
                    <strong>@filteredEvents.Count</strong>
                </article>

                @foreach (var level in AllLevels)
                {
                    <button type="button"
                            class="metric-card level-toggle @(IsLevelVisible(level) ? "active" : "muted") @GetLevelClass(level)"
                            @onclick="() => ToggleLevel(level)">
                        <span>@level</span>
                        <strong>@levelCounts[level]</strong>
                    </button>
                }
            </section>

            @if (filteredEvents.Count == 0)
            {
                <section class="status-panel">
                    <h2>No events match the current filters</h2>
                    <p>Try clearing a filter or broadening the query.</p>
                </section>
            }
            else
            {
                <section class="timeline-layout">
                    <section class="timeline-shell">
                        <div class="timeline-header">
                            <span>Timestamp</span>
                            <span>Level</span>
                            <span>Source</span>
                            <span>Message</span>
                        </div>

                        @foreach (var logEvent in filteredEvents)
                        {
                            <button type="button"
                                    class="timeline-event @(ReferenceEquals(logEvent, selectedEvent) ? "selected" : null)"
                                    style="@GetSourceStyle(logEvent.SourcePath)"
                                    @onclick="() => SelectEvent(logEvent)">
                                <span class="timestamp">@logEvent.Timestamp.LocalDateTime.ToString("yyyy-MM-dd HH:mm:ss.fff", CultureInfo.InvariantCulture)</span>
                                <span class="level @GetLevelClass(logEvent.Level)">@logEvent.Level</span>
                                <span class="source">@logEvent.SourceAlias</span>
                                <span class="message">@logEvent.Message</span>
                            </button>
                        }
                    </section>

                    <aside class="inspector-shell @(selectedEvent is not null && _isInspectorModalOpen ? "modal-open" : null)">
                        <button type="button" class="inspector-backdrop" @onclick="CloseInspector">Close details</button>

                        @if (selectedEvent is null)
                        {
                            <section class="status-panel inspector-empty">
                                <h2>No event selected</h2>
                                <p>Pick a row from the timeline to inspect it.</p>
                            </section>
                        }
                        else
                        {
                            <section class="inspector-panel">
                                <header class="inspector-header">
                                    <div class="inspector-title-row">
                                        <span class="level @GetLevelClass(selectedEvent.Level)">@selectedEvent.Level</span>
                                        <button type="button" class="inspector-close" @onclick="CloseInspector">Close</button>
                                    </div>
                                    <strong>@selectedEvent.Message</strong>
                                </header>

                                <div class="event-block">
                                    <h3>Timestamp</h3>
                                    <pre>@selectedEvent.Timestamp.LocalDateTime.ToString("yyyy-MM-dd HH:mm:ss.fff zzz", CultureInfo.InvariantCulture)</pre>
                                </div>

                                <div class="event-block">
                                    <h3>Source</h3>
                                    <pre>@selectedEvent.SourcePath</pre>
                                </div>

                                @if (selectedEvent.Properties.Count > 0)
                                {
                                    <div class="event-block">
                                        <h3>Properties</h3>
                                        <div class="property-list">
                                            @foreach (var property in selectedEvent.Properties.OrderBy(property => property.Key, StringComparer.OrdinalIgnoreCase))
                                            {
                                                <div class="property-row">
                                                    <div class="property-header-row">
                                                        <span class="property-name">@property.Key</span>
                                                        <button type="button"
                                                                class="property-filter-button"
                                                                title="Filter to this property value"
                                                                @onclick="() => ApplyPropertyFilter(property.Key, property.Value)">
                                                            <svg viewBox="0 0 16 16" aria-hidden="true">
                                                                <path d="M2 3h12l-4.75 5.1v3.3l-2.5 1.6V8.1z"></path>
                                                            </svg>
                                                        </button>
                                                    </div>
                                                    <pre>@property.Value</pre>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                }

                                @if (!string.IsNullOrWhiteSpace(selectedEvent.Exception))
                                {
                                    <div class="event-block">
                                        <h3>Exception</h3>
                                        <pre>@selectedEvent.Exception</pre>
                                    </div>
                                }

                                <div class="event-block">
                                    <h3>Raw</h3>
                                    <pre>@selectedEvent.Raw</pre>
                                </div>
                            </section>
                        }
                    </aside>
                </section>
            }
        }
    }
</div>

@code {
    private string _draftText = string.Empty;
    private string _draftPropertyName = string.Empty;
    private string _draftPropertyValue = string.Empty;
    private string _draftSource = string.Empty;
    private string _appliedText = string.Empty;
    private string _appliedPropertyName = string.Empty;
    private string _appliedPropertyValue = string.Empty;
    private string _appliedSource = string.Empty;
    private readonly HashSet<string> _hiddenLevels = new(StringComparer.OrdinalIgnoreCase);
    private IReadOnlyList<string> _sourceErrors = [];
    private string _sourceKind = "File";
    private string _sourceInput = string.Empty;
    private bool _isAddingSource;
    private bool _controlsCollapsed;
    private bool _isInspectorModalOpen;
    private LogEventRecord? _selectedEvent;
    private static readonly string[] AllLevels = ["Verbose", "Debug", "Information", "Warning", "Error", "Fatal"];

    protected override void OnInitialized() => Session.Changed += OnSessionChanged;

    public void Dispose() => Session.Changed -= OnSessionChanged;

    private void OnSessionChanged() => _ = InvokeAsync(StateHasChanged);

    private void ApplyFilters()
    {
        _appliedText = _draftText.Trim();
        _appliedPropertyName = _draftPropertyName.Trim();
        _appliedPropertyValue = _draftPropertyValue.Trim();
        _appliedSource = _draftSource;
    }

    private void ClearFilters()
    {
        _draftText = string.Empty;
        _draftPropertyName = string.Empty;
        _draftPropertyValue = string.Empty;
        _draftSource = string.Empty;
        _appliedText = string.Empty;
        _appliedPropertyName = string.Empty;
        _appliedPropertyValue = string.Empty;
        _appliedSource = string.Empty;
        _hiddenLevels.Clear();
        _isInspectorModalOpen = false;
        _selectedEvent = null;
    }

    private void ApplyPropertyFilter(string name, string value)
    {
        _draftPropertyName = name;
        _draftPropertyValue = value;
        _appliedPropertyName = name;
        _appliedPropertyValue = value;
        _isInspectorModalOpen = false;
        _selectedEvent = null;
    }

    private async Task AddSourceAsync()
    {
        _sourceErrors = [];

        if (string.IsNullOrWhiteSpace(_sourceInput))
        {
            _sourceErrors = ["Give Lathe a path or pattern first."];
            return;
        }

        _isAddingSource = true;

        try
        {
            var value = _sourceInput.Trim();
            _sourceErrors = _sourceKind switch
            {
                "Glob" => await SessionController.AddInputsAsync([], [value], [], CancellationToken.None),
                "Rolling" => await SessionController.AddInputsAsync([], [], [value], CancellationToken.None),
                _ => await SessionController.AddInputsAsync([value], [], [], CancellationToken.None),
            };

            if (_sourceErrors.Count == 0)
            {
                _sourceInput = string.Empty;
            }
        }
        finally
        {
            _isAddingSource = false;
        }
    }

    private void SelectEvent(LogEventRecord logEvent)
    {
        _selectedEvent = logEvent;
        _isInspectorModalOpen = true;
    }

    private void CloseInspector() => _isInspectorModalOpen = false;

    private void ToggleControls() => _controlsCollapsed = !_controlsCollapsed;

    private void ToggleLevel(string level)
    {
        if (!_hiddenLevels.Add(level))
        {
            _hiddenLevels.Remove(level);
        }
    }

    private LogEventRecord? GetSelectedEvent(IReadOnlyList<LogEventRecord> events)
    {
        if (events.Count == 0)
        {
            _isInspectorModalOpen = false;
            _selectedEvent = null;
            return null;
        }

        if (_selectedEvent is not null && events.Contains(_selectedEvent))
        {
            return _selectedEvent;
        }

        _selectedEvent = events[0];
        return _selectedEvent;
    }

    private IEnumerable<LogEventRecord> FilterWithoutLevelToggles(IEnumerable<LogEventRecord> events)
    {
        var filtered = events;

        if (!string.IsNullOrWhiteSpace(_appliedSource))
        {
            filtered = filtered.Where(logEvent => string.Equals(logEvent.SourceAlias, _appliedSource, StringComparison.OrdinalIgnoreCase));
        }

        if (string.IsNullOrWhiteSpace(_appliedText))
        {
            return FilterByProperty(filtered);
        }

        return FilterByProperty(filtered.Where(logEvent =>
            Contains(logEvent.Message, _appliedText) ||
            Contains(logEvent.Exception, _appliedText) ||
            Contains(logEvent.Raw, _appliedText)));
    }

    private IEnumerable<LogEventRecord> ApplyLevelToggles(IEnumerable<LogEventRecord> events) =>
        _hiddenLevels.Count == 0
            ? events
            : events.Where(logEvent => !_hiddenLevels.Contains(logEvent.Level));

    private IEnumerable<LogEventRecord> FilterByProperty(IEnumerable<LogEventRecord> events)
    {
        if (string.IsNullOrWhiteSpace(_appliedPropertyName) && string.IsNullOrWhiteSpace(_appliedPropertyValue))
        {
            return events;
        }

        return events.Where(logEvent => MatchesProperty(logEvent.Properties, _appliedPropertyName, _appliedPropertyValue));
    }

    private static bool Contains(string? value, string text) =>
        value?.Contains(text, StringComparison.OrdinalIgnoreCase) == true;

    private static bool MatchesProperty(IReadOnlyDictionary<string, string> properties, string name, string value)
    {
        if (!string.IsNullOrWhiteSpace(name))
        {
            if (!properties.TryGetValue(name, out var propertyValue))
            {
                return false;
            }

            return string.IsNullOrWhiteSpace(value) || Contains(propertyValue, value);
        }

        return properties.Values.Any(propertyValue => Contains(propertyValue, value));
    }

    private static IReadOnlyDictionary<string, int> CountLevels(IEnumerable<LogEventRecord> events)
    {
        var counts = AllLevels.ToDictionary(level => level, _ => 0, StringComparer.OrdinalIgnoreCase);

        foreach (var logEvent in events)
        {
            if (!counts.ContainsKey(logEvent.Level))
            {
                continue;
            }

            counts[logEvent.Level]++;
        }

        return counts;
    }

    private string GetActiveFilterSummary()
    {
        List<string> filters = [];

        if (!string.IsNullOrWhiteSpace(_appliedText))
        {
            filters.Add($"text: {_appliedText}");
        }

        if (!string.IsNullOrWhiteSpace(_appliedPropertyName) || !string.IsNullOrWhiteSpace(_appliedPropertyValue))
        {
            filters.Add($"property: {_appliedPropertyName}={_appliedPropertyValue}");
        }

        if (!string.IsNullOrWhiteSpace(_appliedSource))
        {
            filters.Add($"source: {_appliedSource}");
        }

        if (_hiddenLevels.Count > 0)
        {
            filters.Add($"levels hidden: {string.Join(", ", _hiddenLevels.OrderBy(level => level, StringComparer.OrdinalIgnoreCase))}");
        }

        return filters.Count == 0
            ? "No active filters"
            : string.Join(" | ", filters);
    }

    private string GetPageClass() => _controlsCollapsed ? "controls-collapsed" : string.Empty;

    private static string GetSourceStyle(string key)
    {
        var hue = Math.Abs(GetStableHashCode(key)) % 360;
        return $"--source-accent: hsl({hue}, 72%, 62%); --source-tint: hsla({hue}, 72%, 58%, 0.10);";
    }

    private static int GetStableHashCode(string value)
    {
        unchecked
        {
            var hash = 23;

            foreach (var character in value)
            {
                hash = (hash * 31) + char.ToUpperInvariant(character);
            }

            return hash;
        }
    }

    private bool IsLevelVisible(string level) => !_hiddenLevels.Contains(level);

    private static string GetLevelClass(string level) => level.ToLowerInvariant() switch
    {
        "verbose" => "verbose",
        "debug" => "debug",
        "information" => "information",
        "warning" => "warning",
        "error" => "error",
        "fatal" => "fatal",
        _ => "information",
    };
}
